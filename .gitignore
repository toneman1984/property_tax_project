# Virtual environment
venv/
.venv/
env/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Environment variables
.env

# IDE settings
.vscode/
.idea/

# Distribution / packaging
*.egg-info/
dist/
build/

# Type checking / testing cache
.mypy_cache/
.pytest_cache/

# Project data files (large, not tracked)
data/raw/*
data/processed/*
data/exports/*

# But keep .gitkeep files
!**/.gitkeep
